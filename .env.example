# ============================================================
# CONFIGURATION PLATEFORME SOC - Copiez ce fichier en .env
# et renseignez vos vraies clés API
# ============================================================

# ─── Wazuh API ───────────────────────────────────────────────
WAZUH_API_URL=https://localhost:55000
WAZUH_API_USER=wazuh
WAZUH_API_PASSWORD=SecretPassword1

# ─── Shuffle SOAR ────────────────────────────────────────────
SHUFFLE_URL=http://localhost:3001
SHUFFLE_API_KEY=VOTRE_CLE_SHUFFLE_ICI

# ─── CTI - AlienVault OTX ────────────────────────────────────
# Inscription gratuite sur : https://otx.alienvault.com
OTX_API_KEY=VOTRE_CLE_OTX_ICI

# ─── CTI - AbuseIPDB ─────────────────────────────────────────
# Inscription gratuite sur : https://www.abuseipdb.com
ABUSEIPDB_API_KEY=VOTRE_CLE_ABUSEIPDB_ICI

# ─── CTI - VirusTotal ────────────────────────────────────────
# Inscription gratuite sur : https://www.virustotal.com
VIRUSTOTAL_API_KEY=VOTRE_CLE_VIRUSTOTAL_ICI

# ─── Configuration Notifications ─────────────────────────────
# Adresse email simulée pour les notifications d'incidents
NOTIFY_EMAIL=soc-analyst@assurance-demo.fr
SOC_TEAM_NAME=SOC Groupe Assurantiel Demo

# ─── Chemins des Rapports ────────────────────────────────────
REPORTS_OUTPUT_DIR=./reports/generated
REPORTS_TEMPLATE_DIR=./reports/templates
